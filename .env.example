# ─── API Server ──────────────────────────────────────────────────────────────

# Puerto TCP donde escucha el servidor Express (OBLIGATORIO)
PORT=8080

# API Key de ElevenLabs para narración TTS de artículos (OBLIGATORIO para audio)
# Obtener en: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here

# Entorno de ejecución (opcional, default: development)
NODE_ENV=development

# Nivel de logs pino (opcional, default: info)
# Valores: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Reservado para futura autenticación (no activo actualmente)
SESSION_SECRET=your_random_secret_here

# ─── App Móvil (Expo) ────────────────────────────────────────────────────────
# Estas variables van en artifacts/xico-mobile/.env.local

# Host y puerto del API server accesible desde el dispositivo (OBLIGATORIO)
# En desarrollo local con dispositivo físico: usa la IP LAN de tu máquina
# Ej: 192.168.1.10:8080
# En producción: api.tudominio.com (sin http://)
EXPO_PUBLIC_DOMAIN=localhost:8080


