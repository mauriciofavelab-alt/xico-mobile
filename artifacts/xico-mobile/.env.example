# Variables de entorno para desarrollo local (fuera de Replit)
# Copia este archivo como .env.local y ajusta los valores

# Dominio base del servidor API (sin protocolo)
# Dentro de Replit: asignado automáticamente ($REPLIT_DEV_DOMAIN)
# Fuera de Replit: usa tu IP local o el dominio donde corre la API
EXPO_PUBLIC_DOMAIN=localhost:8080

# Supabase project · required for auth, sellos, saved articles, profile,
# editor letters, and most remote data. Missing values degrade gracefully
# (see constants/supabase.ts) — the app still mounts, but auth + remote
# calls reject with a clear "Supabase not configured" error.
# Find these at https://supabase.com/dashboard/project/_/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo necesario dentro de Replit — ignorar fuera
# EXPO_PACKAGER_PROXY_URL=
# REACT_NATIVE_PACKAGER_HOSTNAME=
# REPL_ID=
